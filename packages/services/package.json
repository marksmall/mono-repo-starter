{
  "name": "@agrimetrics/services",
  "version": "7.14.0",
  "description": "Agrimetrics services library — DSP Toolkit",
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./AzureService": {
      "types": "./dist/AzureService/index.d.ts",
      "import": "./dist/AzureService/index.js"
    },
    "./BaseService": {
      "types": "./dist/BaseService/index.d.ts",
      "import": "./dist/BaseService/index.js"
    },
    "./CatalogService": {
      "types": "./dist/CatalogService/index.d.ts",
      "import": "./dist/CatalogService/index.js"
    },
    "./ControlledListService": {
      "types": "./dist/ControlledListService/index.d.ts",
      "import": "./dist/ControlledListService/index.js"
    },
    "./DataIngestionService": {
      "types": "./dist/DataIngestionService/index.d.ts",
      "import": "./dist/DataIngestionService/index.js"
    },
    "./DataProtectionService": {
      "types": "./dist/DataProtectionService/index.d.ts",
      "import": "./dist/DataProtectionService/index.js"
    },
    "./FileManagementService": {
      "types": "./dist/FileManagementService/index.d.ts",
      "import": "./dist/FileManagementService/index.js"
    },
    "./GeoService": {
      "types": "./dist/GeoService/index.d.ts",
      "import": "./dist/GeoService/index.js"
    },
    "./GlobalSearchService": {
      "types": "./dist/GlobalSearchService/index.d.ts",
      "import": "./dist/GlobalSearchService/index.js"
    },
    "./IdentitiesService": {
      "types": "./dist/IdentitiesService/index.d.ts",
      "import": "./dist/IdentitiesService/index.js"
    },
    "./NotificationService": {
      "types": "./dist/NotificationService/index.d.ts",
      "import": "./dist/NotificationService/index.js"
    },
    "./OntologyService": {
      "types": "./dist/OntologyService/index.d.ts",
      "import": "./dist/OntologyService/index.js"
    },
    "./TilesService": {
      "types": "./dist/TilesService/index.d.ts",
      "import": "./dist/TilesService/index.js"
    },
    "./VocabService": {
      "types": "./dist/VocabService/index.d.ts",
      "import": "./dist/VocabService/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=24.12.0"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint './src/**/*.{js,ts,tsx}'",
    "lint:fix": "eslint './src/**/*.{js,ts,tsx}' --fix",
    "format": "prettier --write \"./src/**/*.{mjs,ts,tsx,json}\"",
    "format:check": "prettier --check \"./src/**/*.{mjs,ts,tsx,json}\"",
    "test": "vitest",
    "test:ci": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage",
    "release": "semantic-release",
    "quality:ci": "npm run lint && npm run format:check && npm run typecheck && npm run test:ci && npm run build"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/"
  },
  "peerDependencies": {
    "notifications-node-client": "^8.2.1"
  },
  "peerDependenciesMeta": {
    "notifications-node-client": {
      "optional": true
    }
  },
  "dependencies": {
    "@types/geojson": "^7946.0.10",
    "fast-xml-parser": "^5.3.5",
    "geojson": "^0.5.0"
  },
  "devDependencies": {
    "@dsp-toolkit/shared-config": "workspace:*",
    "@dsp-toolkit/typescript-config": "workspace:*",
    "@tpzdsp/eslint-config-dsp": "^4.0.0",
    "@types/node": "^24.12.2",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitest/coverage-istanbul": "^4.1.2",
    "@vitest/eslint-plugin": "^1.6.15",
    "eslint": "^9.39.4",
    "eslint-plugin-no-only-tests": "^3.3.0",
    "husky": "^9.0.7",
    "knip": "^6.3.0",
    "msw": "^2.12.14",
    "notifications-node-client": "^8.2.1",
    "prettier": "^3.8.1",
    "semantic-release": "^25.0.2",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.2",
    "@testing-library/jest-dom": "^6.9.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.2"
  }
}
