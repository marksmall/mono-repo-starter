{
  "name": "dsp-toolkit",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=24.12.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "prepare": "husky",
    "postinstall": "if [ \"$CI\" != \"true\" ] && [ -d .git ] && [ -f ./postinstall.sh ]; then ./postinstall.sh; fi",
    "bootstrap:check": "node ./scripts/bootstrap-check.mjs",
    "new:package": "node ./scripts/create-package.mjs",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "format": "turbo format",
    "format:check": "turbo format:check",
    "test": "turbo test",
    "test:ci": "turbo test:ci",
    "quality:ci": "turbo lint format:check typecheck test:ci build",
    "quality:ci:changed": "turbo lint format:check typecheck test:ci build --filter=[origin/main...HEAD]",
    "quality:ci:services": "pnpm run quality:ci -- --filter=@agrimetrics/services",
    "quality:ci:events": "pnpm run quality:ci -- --filter=@agrimetrics/agrieventlib",
    "quality:ci:types": "pnpm run quality:ci -- --filter=@agrimetrics/service-event-types",
    "release": "turbo release",
    "release:services": "pnpm --filter @agrimetrics/services exec semantic-release",
    "release:events": "pnpm --filter @agrimetrics/agrieventlib exec semantic-release",
    "release:types": "pnpm --filter @agrimetrics/service-event-types exec semantic-release",
    "clean": "turbo clean",
    "clean:all": "turbo clean && rm -rf node_modules .turbo packages/*/node_modules",
    "unused:code": "knip",
    "syncpack:list": "syncpack list-mismatches",
    "syncpack:fix": "syncpack fix-mismatches",
    "syncpack:lint": "syncpack lint"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "knip": "^5.88.1",
    "prettier": "^3.8.1",
    "syncpack": "^13.0.4",
    "turbo": "^2.5.0",
    "vite": "^8.0.8",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.4"
  },
  "pnpm": {
    "overrides": {
      "jiti": "^2.0.0"
    }
  }
}
